name: Reusable Maven Central Release Publish

on:
    workflow_call:
        inputs:
            java-version:
                required: false
                type: string
                default: '25'
            java-distribution:
                required: false
                type: string
                default: temurin
            maven-opts:
                required: false
                type: string
                default: --sun-misc-unsafe-memory-access=allow
            release-maven-profiles:
                required: false
                type: string
                default: central-release,generate-javadoc-and-source
            maven-server-id:
                required: false
                type: string
                default: central
        secrets:
            CENTRAL_USERNAME:
                required: true
            CENTRAL_PASSWORD:
                required: true
            GPG_PRIVATE_KEY:
                required: true
            GPG_PASSPHRASE:
                required: true

jobs:
    publish:
        name: Publish Maven release
        runs-on: ubuntu-latest

        permissions:
            contents: read

        steps:
            -   uses: actions/checkout@v4

            -   uses: actions/setup-java@v4
                with:
                    java-version: ${{ inputs.java-version }}
                    distribution: ${{ inputs.java-distribution }}
                    cache: maven
                    server-id: ${{ inputs.maven-server-id }}
                    server-username: CENTRAL_USERNAME
                    server-password: CENTRAL_PASSWORD
                    gpg-private-key: ${{ secrets.GPG_PRIVATE_KEY }}
                    gpg-passphrase: GPG_PASSPHRASE

            -   name: Publish package
                env:
                    MAVEN_OPTS: ${{ inputs.maven-opts }}
                    CENTRAL_USERNAME: ${{ secrets.CENTRAL_USERNAME }}
                    CENTRAL_PASSWORD: ${{ secrets.CENTRAL_PASSWORD }}
                    GPG_PASSPHRASE: ${{ secrets.GPG_PASSPHRASE }}
                    MAVEN_GPG_PASSPHRASE: ${{ secrets.GPG_PASSPHRASE }}
                run: mvn -B deploy -P${{ inputs.release-maven-profiles }}
